ata 4-4: US Company Market Share\ndata_4_4 = [\n    [\"company\", \"market_share_percent\"],\n    [\"Hexcel\", 12],\n    [\"Solvay (Cytec)\", 10],\n    [\"Teijin US\", 5],\n    [\"Others\", 3],\n]\n\nwith open('/mnt/user-data/outputs/assets/data/data_4_4_usa_company_market_share.csv', 'w', newline='') as f:\n    writer = csv.writer(f)\n    writer.writerows(data_4_4)\n\nprint(\"All data files created successfully\")\nPYEOF", "verdict": "pass"}
