2026-05-07 08:59:02 - deerflow.agents.middlewares.sandbox_audit_middleware - INFO - [SandboxAudit] {"timestamp": "2026-05-07T08:59:02.580136+00:00", "thread_id": "debug-thread-003", "command": "python3 << 'PYEOF'\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nimport matplotlib.font_manager as fm\nimport pandas as pd\nimport numpy as np\n\n# Try to find Chinese font\nfont_paths = [\n    '/usr/share/fonts/truetype/wqy/wqy-zenhei.ttc',\n    '/usr/share/fonts/truetype/wqy/wqy-microhei.ttc',\n    '/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc',\n    '/usr/share/fonts/noto-cjk/NotoSansCJK-Regular.ttc',\n    '/usr/share/fonts/truetype/noto/NotoSansCJK-Regular.ttc',\n]\n\nchinese_font = None\nfor fp in font_paths:\n    try:\n        fm.fontManager.addfont(fp)\n        chinese_font = fm.fontManager.font.ttName('family')\n        break\n    except:\n        pass\n\nif chinese_font is None:\n    # Fallback: use any available sans\n    plt.rcParams['font.sans-serif'] = ['DejaVu Sans', 'WenQuanYi Micro Hei', 'SimHei', 'Arial Unicode MS']\n    plt.rcParams['axes.unicode_minus'] = False\nelse:\n    plt.rcParams['font.sans-serif'] = [chinese_font, 'DejaVu Sans']\n    plt.rcParams['axes.unicode_minus'] = False\n\n# ========================\n# Figure 1-1: Market Size Trend\n# ========================\ndf1 = pd.read_csv('/mnt/user-data/outputs/assets/data/data_1_1_market_size_trend.csv')\n\nfig1, ax1 = plt.subplots(figsize=(12, 6.5))\nyears = df1['year'].astype(str)\n\nax1.plot(years, df1['global_cf_market_usd_billion'], marker='o', linewidth=2.5, color='#1E3A8A', label='Global CF Market', markersize=8)\nax1.plot(years, df1['carbon_fabric_market_usd_billion'], marker='s', linewidth=2.5, color='#DC2626', label='Carbon Fabric Market', markersize=8)\n\nax1.set_ylabel('Market Size (USD Billion)', fontsize=12)\nax1.set_title('Figure 1-1 Global Carbon Fiber Market & Carbon Fabric Market Size Trend (2024-2033)', fontsize=14, fontweight='bold')\nax1.legend(fontsize=11)\nax1.grid(True, alpha=0.3)\nax1.set_ylim(0, 10)\n\n# Add value labels\nfor i, row in df1.iterrows():\n    ax1.annotate(f\"${row['global_cf_market_usd_billion']:.2f}B\", \n                (row['year'], row['global_cf_market_usd_billion']), \n                textcoords=\"offset points\", xytext=(0,12), ha='center', fontsize=8, color='#1E3A8A')\n    ax1.annotate(f\"${row['carbon_fabric_market_usd_billion']:.2f}B\", \n                (row['year'], row['carbon_fabric_market_usd_billion']), \n                textcoords=\"offset points\", xytext=(0,-18), ha='center', fontsize=8, color='#DC2626')\n\nax1.text(0.5, -0.15, 'Data Source: Mordor Intelligence, GMInsights, CCIA (2024-2025)', \n         transform=ax1.transAxes, ha='center', fontsize=9, style='italic', color='#6B7280')\n\nplt.tight_layout()\nplt.savefig('/mnt/user-data/outputs/assets/charts/fig_1_1_market_size_trend.png', dpi=200, bbox_inches='tight')\nplt.close()\n\n# ========================\n# Figure 1-2: China Capacity & Yield\n# ========================\ndf2 = pd.read_csv('/mnt/user-data/outputs/assets/data/data_1_2_china_capacity_yield.csv')\n\nfig2, ax2 = plt.subplots(figsize=(10, 6))\nyears = df2['year'].astype(str)\nx = np.arange(len(years))\nwidth = 0.3\n\nbars1 = ax2.bar(x - width/2, df2['capacity_tons']/10000, width, label='Capacity (10k tons)', color='#1E3A8A', edgecolor='white')\nbars2 = ax2.bar(x + width/2, df2['yield_tons']/10000, width, label='Yield (10k tons)', color='#DC2626', edgecolor='white')\n\n# Add consumption line\nax3 = ax2.twinx()\nax3.plot(x, df2['consumption_tons']/10000, marker='D', linewidth=2.5, color='#16A34A', label='Consumption (10k tons)', markersize=8)\n\nax2.set_ylabel('Capacity / Yield (10,000 tons)', fontsize=12)\nax3.set_ylabel('Consumption (10,000 tons)', fontsize=12)\nax2.set_title('Figure 1-2 China Carbon Fiber Capacity, Yield & Consumption Trend (2021-2024)', fontsize=14, fontweight='bold')\nax2.set_xticks(x)\nax2.set_xticklabels(years)\n\n# Add utilization rate annotations\nfor i, (_, row) in enumerate(df2.iterrows()):\n    util = row['yield_tons'] / row['capacity_tons'] * 100\n    ax2.annotate(f'{util:.1f}%', (x[i], row['yield_tons']/10000), \n                textcoords=\"offset points\", xytext=(0, 8), ha='center', fontsize=9, color='#EA580C', fontweight='bold')\n\n# Combine legends\nlines1, labels1 = ax2.get_legend_handles_labels()\nlines2, labels2 = ax3.get_legend_handles_labels()\nax2.legend(lines1 + lines2, labels1 + labels2, loc='upper left', fontsize=10)\nax2.grid(True, alpha=0.3, axis='y')\n\nax2.text(0.5, -0.2, 'Data Source: CCIA, China Carbon Fiber Industry Association (2024)', \n         transform=ax2.transAxes, ha='center', fontsize=9, style='italic', color='#6B7280')\n\nplt.tight_layout()\nplt.savefig('/mnt/user-data/outputs/assets/charts/fig_1_2_china_capacity_yield.png', dpi=200, bbox_inches='tight')\nplt.close()\n\nprint(\"Charts generated successfully!\")\nprint(f\"Fig 1-1: /mnt/user-data/outputs/assets/charts/fig_1_1_market_size_trend.png\")\nprint(f\"Fig 1-2: /mnt/user-data/outputs/assets/charts/fig_1_2_china_capacity_yield.png\")\nPYEOF", "verdict": "pass"}
