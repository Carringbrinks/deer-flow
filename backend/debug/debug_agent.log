                             colors=colors, startangle=140, pctdistance=0.85,\n                                   textprops={'fontsize': 12})\n\nfor autotext in autotexts:\n    autotext.set_fontsize(11)\n    autotext.set_fontweight('bold')\n\nax.set_title('全球碳纤维市场区域分布（2024年）', fontsize=15, fontweight='bold', pad=20)\n\nplt.tight_layout()\nplt.savefig('/mnt/user-data/outputs/assets/charts/fig_2_1_regional_distribution.png', dpi=150, bbox_inches='tight')\nplt.close()\n\n# ============================================================\n# Fig 2-2: Market Trend (Line Chart)\n# ============================================================\nfig, ax1 = plt.subplots(figsize=(12, 6))\n\nyears = [2020, 2021, 2022, 2023, 2024, 2025, 2026, 2027, 2028, 2029, 2030]\ncf_market = [30.0, 34.5, 38.2, 42.0, 49.0, 52.5, 56.0, 60.0, 63.5, 66.5, 68.2]\nfabric_market = [28.0, 31.5, 35.0, 38.5, 42.0, 45.5, 49.5, 54.0, 59.0, 64.5, 70.5]\n\nline1 = ax1.plot(years, cf_market, marker='o', linewidth=2.5, color=COLORS['blue'], label='碳纤维市场', markersize=6)\nax1.set_xlabel('年份', fontsize=12)\nax1.set_ylabel('市场规模（亿美元）', fontsize=12, color=COLORS['blue'])\nax1.tick_params(axis='y', labelcolor=COLORS['blue'])\nax1.set_ylim(0, 80)\n\n# Add value labels\nfor i, (y, v) in enumerate(zip(years, cf_market)):\n    if y in [2020, 2024, 2030]:\n        ax1.annotate(f'{v}', (y, v), textcoords=\"offset points\", xytext=(0, 10), ha='center', fontsize=9)\n\nline2 = ax1.plot(years, fabric_market, marker='s', linewidth=2.5, color=COLORS['red'], label='碳纤维织物市场', markersize=6)\nfor i, (y, v) in enumerate(zip(years, fabric_market)):\n    if y in [2020, 2024, 2030]:\n        ax1.annotate(f'{v}', (y, v), textcoords=\"offset points\", xytext=(0, -15), ha='center', fontsize=9)\n\n# Shade forecast area\nax1.axvline(x=2024, color='gray', linestyle='--', linewidth=1, alpha=0.5)\nax1.text(2024.3, 75, '预测区间', fontsize=10, color='gray', alpha=0.7)\n\nax1.set_title('全球碳纤维市场规模与碳纤维织物市场规模趋势（2020-2030）', fontsize=14, fontweight='bold', pad=15)\nax1.legend(loc='upper left', fontsize=11)\nax1.grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.savefig('/mnt/user-data/outputs/assets/charts/fig_2_2_market_trend.png', dpi=150, bbox_inches='tight')\nplt.close()\n\n# ============================================================\n# Fig 2-3: Consumption Structure (Pie Chart)\n# ============================================================\nfig, ax = plt.subplots(figsize=(10, 7))\n\nlabels = ['航空航天', '风电能源', '体育休闲', '汽车轻量化', '其他', '建筑加固']\nsizes = [23, 23, 18, 17, 12, 7]\ncolors_pie = [COLORS['blue'], COLORS['green'], COLORS['orange'], COLORS['red'], COLORS['gray'], COLORS['purple']]\nexplode = (0.05, 0.05, 0, 0, 0, 0)\n\nwedges, texts, autotexts = ax.pie(sizes, explode=explode, labels=labels, autopct='%1.1f%%',\n                                   colors=colors_pie, startangle=90, pctdistance=0.85,\n                                   textprops={'fontsize': 11})\n\nfor autotext in autotexts:\n    autotext.set_fontsize(10)\n    autotext.set_fontweight('bold')\n\nax.set_title('全球碳纤维消费结构（2024年）', fontsize=15, fontweight='bold', pad=20)\n\nplt.tight_layout()\nplt.savefig('/mnt/user-data/outputs/assets/charts/fig_2_3_consumption_structure.png', dpi=150, bbox_inches='tight')\nplt.close()\n\nprint(\"All 3 charts generated successfully!\")\nPYEOF", "verdict": "pass"}
